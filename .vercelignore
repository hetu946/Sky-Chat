# Vercel 忽略文件 - 比 .gitignore 优先级更高

# Git 版本控制
.git
.git/**

# 依赖目录
node_modules
packages/*/node_modules

# 构建产物和缓存
.next
.next/cache/**
.nuxt
dist
build
.cache

# IDE 和编辑器
.vscode
.idea
.DS_Store

# 日志和临时文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 压缩文件
*.zip
*.rar
*.tar.gz
*.7z

# 大型媒体文件
*.mp4
*.avi
*.mov
*.mkv

# PDF 和可执行文件
*.pdf
*.exe
*.dmg

# Python 虚拟环境
venv
.venv
__pycache__
*.pyc

# 其他大目录
scripts
test
tests
coverage

# 文档
*.md
!README.md
docs
