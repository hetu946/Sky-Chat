# Vercel 忽略文件 - 比 .gitignore 优先级更高

# Git 版本控制
.git
.git/**

# 依赖目录
node_modules
node_modules/**
packages/*/node_modules
packages/*/node_modules/**
../sky-monitor-sdk/node_modules

# pnpm 虚拟存储 - 关键！Vercel 上传时会包含所有平台的文件
.pnpm
.pnpm/**
.pnpm-store
.pnpm-store/**

# 构建产物和缓存
.next
.next/**
.next/cache/**
.nuxt
dist
build
.cache

# 生成的文件目录 - 必须排除！
generated
generated/**
generated/*/**
generated/**/**
!/generated/.gitkeep

# Prisma 相关 - 只排除 migrations，构建时需要 schema.prisma
prisma/migrations
prisma/migrations/**

# IDE 和编辑器
.vscode
.vscode/**
.idea
.DS_Store

# 日志和临时文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 压缩文件
*.zip
*.rar
*.tar.gz
*.7z

# 大型媒体文件
*.mp4
*.avi
*.mov
*.mkv

# PDF 和可执行文件
*.pdf
*.exe
*.dmg

# Python 虚拟环境
venv
.venv
__pycache__
*.pyc

# 其他大目录
scripts
scripts/**
test
tests
tests/**
coverage
coverage/**

# 文档
*.md
!README.md
docs
docs/**

# Husky Git hooks - Vercel 不需要
.husky
.husky/**
!.husky/_/.gitkeep

# 本地监控 SDK
sky-monitor-sdk
sky-monitor-sdk/**
packages/sky-monitor-sdk
packages/sky-monitor-sdk/**
