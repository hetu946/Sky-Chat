# ============================================
# Sky-Chat 环境变量配置模板
# ============================================
# 复制此文件为 .env.local 并填写实际值
# .env.local 不应该被提交到 Git！

# ============================================
# 数据库（Vercel 部署需要使用云数据库）
# ============================================
# 本地开发：
# DATABASE_URL="postgresql://skychat:password123@127.0.0.1:5433/skychat"

# Neon 示例（推荐，免费）：
# DATABASE_URL="postgresql://username:password@ep-cool-name-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Supabase 示例：
# DATABASE_URL="postgresql://postgres.xxx:xxx@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require"

# ============================================
# Auth.js 认证配置（重要！）
# ============================================
# 生产环境必须使用强随机密钥（至少 32 个字符）
# 生成方法：openssl rand -base64 32
AUTH_SECRET="your-strong-secret-key-here-min-32-chars"

# 本地开发设为 true，Vercel 上也设为 true
AUTH_TRUST_HOST="true"

# ============================================
# OAuth 第三方登录（可选）
# ============================================
# Google OAuth：
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# GitHub OAuth：
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# ============================================
# AI API 配置
# ============================================
# 硅基流动 API Key（用于 AI 对话功能）
# 在 https://account.siliconflow.cn 获取 API Key
SILICONFLOW_API_KEY=""

# ============================================
# 其他可选配置
# ============================================
# 分析工具（可选）
# ANALYZE=""
